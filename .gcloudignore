# This file specifies files that are *not* uploaded to Google Cloud
.gcloudignore
.git
.gitignore
__pycache__/
*.pyc
.env
venv/
.venv/
# staticfiles/ is intentionally NOT excluded — WhiteNoise serves files from
# staticfiles/ at runtime, so the collected assets must be uploaded.
# Run `python manage.py collectstatic --noinput` before deploying.
