DB_NAME=CS348_Project
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=true

# Production / App Engine (set in cloud console, not in a committed file):
# DJANGO_SECRET_KEY=long-random-string
# DJANGO_DEBUG=false
# DJANGO_ALLOWED_HOSTS=.appspot.com,your-service-dot-project.appspot.com
# CLOUD_SQL_CONNECTION_NAME=project-id:region:instance-name
# DB_NAME=...
# DB_USER=...
# DB_PASSWORD=...
